# ─────────────────────────────────────────────────────────────────────
# Vision Demo · Variables de entorno
# ─────────────────────────────────────────────────────────────────────
# Copiar este archivo a `.env` (que NUNCA se commitea) y completar las
# keys que necesites. Si una key falta, el modelo asociado aparece como
# "no configurado" en /vision-lab y no rompe la UI.
#
# Documentación completa de cada provider en `docs/vision-demo-api.md`.

# ─────────── Roboflow Universe ───────────
# Free tier: 1,000 inferencias/mes
# https://universe.roboflow.com → Settings → API
ROBOFLOW_API_KEY=
ROBOFLOW_API_URL=https://detect.roboflow.com

# ─────────── Google Cloud Vision + Video Intelligence ───────────
# Free tier: 1,000 unidades/mes
# Crear service account JSON y apuntar GOOGLE_APPLICATION_CREDENTIALS al path
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# ─────────── AWS Rekognition ───────────
# Free tier: 5,000 imágenes/mes (primeros 12 meses)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─────────── Azure AI Vision / Face API ───────────
# Free tier: 5,000 transacciones/mes
# ATENCIÓN: Face API tiene restricciones legales — solo aprobado para uso comercial limitado
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

# ─────────── Hugging Face Inference (VLMs experimentales) ───────────
# https://huggingface.co/settings/tokens (rol "read")
HF_TOKEN=

# ─────────── Modo de operación del backend ───────────
# Si "true" intenta correr modelos locales (YOLO, MediaPipe, EasyOCR, InsightFace)
# Si "false" prioriza APIs externas (cuando estén configuradas)
USE_LOCAL_MODELS=true

# ─────────── URL del backend de visión (Fase 2+) ───────────
# Si no está, /vision-lab corre con mock predictions (Fase 1)
VISION_API_URL=

# ─────────────────────────────────────────────────────────────────────
# REGLAS DE SEGURIDAD
# ─────────────────────────────────────────────────────────────────────
# 1. Nunca commits `.env` real al repo (ya está en .gitignore)
# 2. Nunca uses `NEXT_PUBLIC_*` para estas keys — quedan expuestas al navegador
# 3. Todas las llamadas a APIs externas se hacen desde el backend Python,
#    nunca desde el cliente
# 4. Rotar keys periódicamente
# 5. En staging/dev usar keys de cuenta separada de producción
